# SalesInject — Environment Variables
# Copy to backend/.env and fill in real values.

# ── Database ─────────────────────────────────────────────────────────────────
# Internal Docker hostname (matches service name in docker-compose.prod.yml)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/salesinject
POSTGRES_USER=salesinject_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_to_a_real_secret_key

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OpenClaw (your SEPARATE VPS) ──────────────────────────────────────────────
# Replace with the actual IP or hostname of your OpenClaw VPS
OPENCLAW_URL=http://YOUR_OPENCLAW_VPS_IP:18789

# ── Exa Search API ────────────────────────────────────────────────────────────
EXA_API_KEY=your-exa-api-key-here

# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your-telegram-bot-token
# Set to your VPS IP (no domain yet) — update to domain when ready
MINI_APP_URL=http://YOUR_VPS_IP
USE_WEBHOOK=true

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Frontend build arg (set in docker-compose.prod.yml args) ─────────────────
# When no domain: use /api/v1 (relative path — works because nginx proxies)
VITE_API_BASE_URL=/api/v1

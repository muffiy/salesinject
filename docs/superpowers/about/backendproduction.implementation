                "goals": brand.campaign_goals,
                "target_niches": brand.target_niches
            }
        }
        
        self.db.execute(
            f"UPDATE users SET metadata = :meta WHERE id = :id",
            {"meta": json.dumps(user_metadata), "id": user.id}

        ]
        avg_engagement = sum([e for e in engagement_rates if e > 0]) / len([e for e in engagement_rates if e > 0]) if any(engagement_rates) else 0
        
        # Update user
        user.role = "influencer"
        user.niche_preferences = influencer.niches
        user.onboarded = True
        user.username = influencer.display_name
        
        # Store metadata

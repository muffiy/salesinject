"""
Telegram Bot - Simple, data-driven conversations.
No complex agents—just data capture and routing.
"""

from aiogram import Router, types
from aiogram.filters import CommandStart
from app.core.hermes import hermes
from app.database import SessionLocal
from app.models import User
import uuid

router = Router()

@router.message(CommandStart())
async def cmd_start(message: types.Message):
    """
    /start handler with user_id from deep link.
    Example: /start abc123def456 (user_id from onboarding)
    """
    args = message.text.split()
    user_id = args[1] if len(args) > 1 else None
    
    if not user_id:
        await message.answer(
            "Welcome to SalesInject! 🚀\n"
            "Please join from our landing page to get started.",
            reply_markup=inline_kb([("Visit SalesInject", "https://salesinject.tn")])
        )
        return
    
    # Lookup user from onboarding
    db = SessionLocal()
    user = db.query(User).filter(User.id == uuid.UUID(user_id)).first()
    
    if not user:
        await message.answer(
            "User not found. Please start from our landing page."
        )
        return
    
    # Link Telegram ID to user
    user.telegram_id = message.from_user.id
    db.commit()
    db.close()
    
    # Route to role-specific welcome
    if user.role == "brand":
        await welcome_brand(message, user)
    elif user.role == "influencer":
        await welcome_influencer(message, user)

async def welcome_brand(message: types.Message, user: User):
    """Welcome brand user."""
    await message.answer(
        f"Welcome {user.first_name}! 🏢\n\n"
        "You're now ready to create campaigns.\n\n"
        "What would you like to do?\n"
        "1. Create a new campaign\n"
        "2. View existing campaigns\n"
